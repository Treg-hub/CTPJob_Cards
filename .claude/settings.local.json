{
  "permissions": {
    "allow": [
      "Bash(flutter pub *)",
      "Bash(flutter analyze *)",
      "Bash(where.exe msedge *)",
      "Bash(\"/c/Program Files \\(x86\\)/Microsoft/Edge/Application/msedge.exe\" --version)",
      "PowerShell($zip = [System.IO.Compression.ZipFile]::OpenRead\\(\\(Resolve-Path 'ctp-job-cards-docs-2026-05-18.zip'\\).Path\\); $zip.Entries | Group-Object { [System.IO.Path]::GetExtension\\($_.Name\\) } | Sort-Object Count -Descending | ForEach-Object { '{0,-6} {1,3} files' -f $_.Name, $_.Count }; $zip.Dispose\\(\\))",
      "Bash(git rm *)",
      "Bash(git push *)",
      "mcp__Claude_in_Chrome__tabs_context_mcp",
      "mcp__Claude_in_Chrome__navigate",
      "mcp__Claude_in_Chrome__browser_batch",
      "Bash(gh repo *)",
      "Bash(gh pr *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(flutter test *)",
      "Bash(git -C \"C:/Users/Admin/CTPJob_Cards\" add .claude/settings.local.json)",
      "Bash(git -C C:/Users/Admin/CTPJob_Cards commit -m ' *)",
      "Bash(git -C \"C:/Users/Admin/CTPJob_Cards\" push origin master)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$json=[Console]::In.ReadToEnd();$d=$json|ConvertFrom-Json;$f=$d.tool_input.file_path;if($f-and($f-match'\\.BACKUP\\.')){Write-Output 'Blocked: do not create .BACKUP files — use git instead';exit 2}",
            "shell": "powershell"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$json=[Console]::In.ReadToEnd();$d=$json|ConvertFrom-Json;$f=$d.tool_input.file_path;if($f-and($f-match'\\.dart$')){flutter analyze $f --no-fatal-infos 2>&1|Select-Object -Last 10}",
            "shell": "powershell",
            "statusMessage": "flutter analyze..."
          }
        ]
      }
    ]
  }
}
