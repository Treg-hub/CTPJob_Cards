<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0000"
    android:orientation="vertical">

    <!-- RED HEADER -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D32F2F"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="⚠️"
            android:textSize="24sp"
            android:gravity="center"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="URGENT JOB ALERT"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPriorityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FF5722"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="P5"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- JOB NUMBER -->
    <TextView
        android:id="@+id/tvJobNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="#230"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:textStyle="bold" />

    <!-- LEVEL / PRIORITY -->
    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:background="#D32F2F"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:text="🔥 CRITICAL - PRIORITY 5"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- LOCATION HIERARCHY -->
    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:background="#33FFFFFF"
        android:gravity="center"
        android:padding="16dp"
        android:text="Mechanical > Workshop A > Lathe 3 > Spindle Bearing"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- CREATED BY -->
    <TextView
        android:id="@+id/tvCreatedBy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="👤 Created by: John Smith"
        android:textColor="#CCCCCC"
        android:textSize="16sp" />

    <!-- DESCRIPTION -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="JOB DESCRIPTION"
        android:textColor="#888888"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="4dp"
        android:background="#22FFFFFF"
        android:padding="16dp"
        android:text="Test description here..."
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ASSIGN TO ME -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAssignSelf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#4CAF50"
            android:text="✓ ASSIGN TO ME"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:cornerRadius="12dp" />

        <!-- I'M BUSY -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImBusy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#FF9800"
            android:text="⏸ I'M BUSY ON ANOTHER JOB"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <!-- DISMISS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#D32F2F"
            android:text="✕ DISMISS ALERT"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            app:strokeColor="#FFCDD2"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="This alarm will continue sounding until you take action"
        android:textColor="#666666"
        android:textSize="12sp" />

</LinearLayout>